# =============================================================
# Smart Quiz Hub — Environment Variables (TEMPLATE)
# =============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# .env is gitignored — NEVER commit it with real secrets.
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=smart_quiz_hub
DB_USERNAME=postgres
DB_PASSWORD=changeme_use_a_strong_password

# Host port exposed by Docker. Change to 5433 if PostgreSQL is
# already running locally on 5432.
DB_PORT=5433

# ── Spring Boot Backend ───────────────────────────────────────
BACKEND_PORT=8080

# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=replace_with_strong_secret_openssl_rand_base64_48
JWT_EXPIRATION_MS=86400000

# ── AI / Groq ─────────────────────────────────────────────────
# Free key at https://console.groq.com/keys  (starts with gsk_)
# For OpenAI instead: OPENAI_BASE_URL=https://api.openai.com  OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace_with_your_groq_api_key
OPENAI_BASE_URL=https://api.groq.com/openai
OPENAI_MODEL=llama-3.3-70b-versatile

AI_SIMILARITY_THRESHOLD=0.30
AI_EMBEDDINGS_ENABLED=true
AI_EMBEDDING_FLOOR=0.50

# ── CORS ──────────────────────────────────────────────────────
# Allowed origins for direct API calls (Swagger UI, API clients).
# With the Angular proxy, browser requests don't hit CORS at all.
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Angular Frontend ──────────────────────────────────────────
FRONTEND_PORT=4200

# Backend URL used by the Angular dev-server proxy (proxy.conf.js).
# Docker : keep http://backend:8080  (internal Docker network hostname)
# Local  : change to http://localhost:8080
BACKEND_URL=http://backend:8080
